+/// <reference path="./bun-test.d.ts" />
+
+import { test } from "bun:test"
+
+import { VerlWorkflowScope } from "../plugins/verl-workflow-scope"
+
+function requireHook<T>(hook: T | undefined, name: string): T {
+  if (hook) return hook
+  throw new Error(`Missing hook: ${name}`)
+}
+
+async function expectBlocked(operation: () => Promise<void>): Promise<void> {
+  try {
+    await operation()
+  } catch (error) {
+    if (error instanceof Error && error.message.includes("/verl-subagent-union-workflow")) return
+    throw error
+  }
+  throw new Error("Expected restricted-agent execution to be blocked")
+}
+
+test("restricts workflow agents to command-activated sessions", async () => {
+  const hooks = await VerlWorkflowScope()
+  const beforeCommand = requireHook(hooks["command.execute.before"], "command.execute.before")
+  const beforeTool = requireHook(hooks["tool.execute.before"], "tool.execute.before")
+  const chatParams = requireHook(hooks["chat.params"], "chat.params")
+  const event = requireHook(hooks.event, "event")
+
+  await expectBlocked(() =>
+    beforeTool(
+      { tool: "task", sessionID: "ordinary-session", callID: "call-phase" },
+      { args: { subagent_type: "workflow-supervisor" } },
+    ),
+  )
+  await expectBlocked(() =>
+    beforeTool(
+      { tool: "task", sessionID: "ordinary-session", callID: "call-normalized" },
+      { args: { subagent_type: " Baseline-Runner " } },
+    ),
+  )
+  await expectBlocked(() =>
+    beforeTool(
+      { tool: "task", sessionID: "ordinary-session", callID: "call-zero-width" },
+      { args: { subagent_type: "\u200Bbaseline-runner" } },
+    ),
+  )
+  await expectBlocked(() =>
+    beforeTool(
+      { tool: "task", sessionID: "ordinary-session", callID: "call-controller" },
+      { args: { subagent_type: "verl-workflow-controller" } },
+    ),
+  )
+  await beforeTool(
+    { tool: "task", sessionID: "ordinary-session", callID: "call-prompt" },
+    { args: { subagent_type: "oracle", prompt: "Review baseline-runner behavior" } },
+  )
+  await beforeTool(
+    { tool: "task", sessionID: "ordinary-session", callID: "call-resume" },
+    { args: { task_id: "ses_unrelated_child" } },
+  )
+  await expectBlocked(() => chatParams({ sessionID: "ordinary-phase", agent: "baseline-runner" }))
+  await expectBlocked(() =>
+    chatParams({ sessionID: "ordinary-controller", agent: "verl-workflow-controller" }),
+  )
+
+  await beforeCommand({ command: "verl-subagent-union-workflow", sessionID: "workflow-session" })
+  await beforeTool(
+    { tool: "task", sessionID: "workflow-session", callID: "call-activated" },
+    { args: { subagent_type: "workflow-supervisor" } },
+  )
+  await beforeTool(
+    { tool: "task", sessionID: "ordinary-session", callID: "call-unrelated" },
+    { args: { subagent_type: "oracle" } },
+  )
+  await chatParams({ sessionID: "workflow-session", agent: "baseline-runner" })
+  await chatParams({ sessionID: "workflow-session", agent: "verl-workflow-controller" })
+
+  await event({
+    event: {
+      type: "session.deleted",
+      properties: { info: { id: "workflow-session" } },
+    },
+  })
+  await expectBlocked(() =>
+    beforeTool(
+      { tool: "task", sessionID: "workflow-session", callID: "call-after-delete" },
+      { args: { subagent_type: "workflow-supervisor" } },
+    ),
+  )
+})
+
+test("authorizes controller children but blocks cross-session workflow continuation", async () => {
+  const hooks = await VerlWorkflowScope({
+    directory: "/home/l30002999",
+    client: {
+      session: {
+        get: async ({ path }) => ({ data: path.id === "phase-child" ? { parentID: "workflow-root" } : {} }),
+        messages: async ({ path }) => ({
+          data: path.id === "phase-child"
+            ? [
+                { info: { role: "user" } },
+                { info: { role: "assistant", agent: "workflow-supervisor" } },
+              ]
+            : [{ info: { role: "assistant", agent: "oracle" } }],
+        }),
+      },
+    },
+  })
+  const beforeCommand = requireHook(hooks["command.execute.before"], "command.execute.before")
+  const beforeTool = requireHook(hooks["tool.execute.before"], "tool.execute.before")
+  const chatParams = requireHook(hooks["chat.params"], "chat.params")
+
+  await beforeCommand({ command: "verl-subagent-union-workflow", sessionID: "workflow-root" })
+  await chatParams({ sessionID: "phase-child", agent: "workflow-supervisor" })
+  await expectBlocked(() =>
+    beforeTool(
+      { tool: "task", sessionID: "ordinary-session" },
+      { args: { task_id: "workflow-root" } },
+    ),
+  )
+  await expectBlocked(() =>
+    beforeTool(
+      { tool: "task", sessionID: "ordinary-session" },
+      { args: { task_id: "phase-child" } },
+    ),
+  )
+  await beforeTool(
+    { tool: "task", sessionID: "ordinary-session" },
+    { args: { task_id: "oracle-child" } },
+  )
+})
