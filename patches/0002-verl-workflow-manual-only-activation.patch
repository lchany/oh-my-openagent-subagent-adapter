index 0000000000000000000000000000000000000000..70becb66ee2785a02098d12f4923755a55923ff5
--- /dev/null
+++ b/verl-subagent-union-workflow/plugins/verl-workflow-scope.ts
@@ -0,0 +1,178 @@
+const WORKFLOW_COMMAND = "verl-subagent-union-workflow"
+
+const RESTRICTED_AGENTS = new Set<string>([
+  "verl-workflow-controller",
+  "baseline-preflight-repair",
+  "baseline-runner",
+  "optimized-preflight-repair",
+  "optimized-runner",
+  "benchmark-comparator",
+  "workflow-supervisor",
+  "run-evidence-analyst",
+  "debug-isolator",
+  "experiment-reporter",
+  "workflow-generalist",
+])
+
+type SessionLookup = {
+  readonly path: { readonly id: string }
+  readonly query: { readonly directory: string }
+}
+
+type PluginClient = {
+  readonly session: {
+    get(input: SessionLookup): Promise<{ readonly data?: { readonly parentID?: string } }>
+    messages(input: SessionLookup): Promise<{ readonly data?: readonly { readonly info: unknown }[] }>
+  }
+}
+
+type PluginContext = {
+  readonly client: PluginClient
+  readonly directory: string
+}
+
+type ChatParamsInput = {
+  readonly sessionID: string
+  readonly agent: string
+}
+
+type CommandInput = {
+  readonly command: string
+  readonly sessionID: string
+  readonly arguments?: string
+}
+
+type ToolInput = {
+  readonly tool: string
+  readonly sessionID: string
+  readonly callID?: string
+}
+
+type ToolOutput = {
+  readonly args: unknown
+}
+
+class WorkflowScopeViolation extends Error {
+  constructor(agent: string) {
+    super(
+      `Agent ${agent} is restricted to the manually invoked /${WORKFLOW_COMMAND} workflow. Invoke that slash command first.`,
+    )
+    this.name = "WorkflowScopeViolation"
+  }
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === "object" && value !== null && !Array.isArray(value)
+}
+
+function normalizeRestrictedAgent(value: unknown): string | undefined {
+  if (typeof value !== "string") return undefined
+  const normalized = value
+    .replace(/[\u200B\u200C\u200D\uFEFF]/g, "")
+    .trim()
+    .replace(/^[\\/"']+|[\\/"']+$/g, "")
+    .trim()
+    .toLowerCase()
+  return RESTRICTED_AGENTS.has(normalized) ? normalized : undefined
+}
+
+function findInlineTeamRestrictedAgent(value: unknown): string | undefined {
+  if (!isRecord(value)) return undefined
+  const inlineSpec = value.inline_spec
+  if (!isRecord(inlineSpec) || !Array.isArray(inlineSpec.members)) return undefined
+  for (const member of inlineSpec.members) {
+    if (!isRecord(member)) continue
+    const restrictedAgent = normalizeRestrictedAgent(member.subagent_type)
+    if (restrictedAgent) return restrictedAgent
+  }
+  return undefined
+}
+
+function findDelegatedRestrictedAgent(tool: string, args: unknown): string | undefined {
+  if (!isRecord(args)) return undefined
+  if (tool === "task" || tool === "call_omo_agent") {
+    return normalizeRestrictedAgent(args.subagent_type)
+  }
+  if (tool === "spawn_agent") {
+    const directAgent = normalizeRestrictedAgent(args.agent)
+    if (directAgent) return directAgent
+    if (!Array.isArray(args.agents)) return undefined
+    for (const item of args.agents) {
+      if (!isRecord(item)) continue
+      const restrictedAgent = normalizeRestrictedAgent(item.agent)
+      if (restrictedAgent) return restrictedAgent
+    }
+    return undefined
+  }
+  return tool === "team_create" ? findInlineTeamRestrictedAgent(args) : undefined
+}
+
+async function getSessionParent(client: PluginClient, directory: string, sessionID: string): Promise<string | undefined> {
+  const response = await client.session.get({ path: { id: sessionID }, query: { directory } })
+  return response.data?.parentID
+}
+
+async function getSessionRestrictedAgent(
+  client: PluginClient,
+  directory: string,
+  sessionID: string,
+): Promise<string | undefined> {
+  const response = await client.session.messages({ path: { id: sessionID }, query: { directory } })
+  for (const message of response.data ?? []) {
+    if (!isRecord(message.info)) continue
+    const restrictedAgent = normalizeRestrictedAgent(message.info.agent)
+    if (restrictedAgent) return restrictedAgent
+  }
+  return undefined
+}
+
+export const VerlWorkflowScope = (async (context?: PluginContext) => {
+  const activatedSessions = new Set<string>()
+  const client = context?.client
+  const directory = context?.directory
+
+  const isAuthorizedSession = async (sessionID: string): Promise<boolean> => {
+    if (activatedSessions.has(sessionID)) return true
+    if (!client || !directory) return false
+    const parentID = await getSessionParent(client, directory, sessionID)
+    return parentID !== undefined && activatedSessions.has(parentID)
+  }
+
+  return {
+    "command.execute.before": async (input: CommandInput) => {
+      if (input.command === WORKFLOW_COMMAND || input.command === `/${WORKFLOW_COMMAND}`) {
+        activatedSessions.add(input.sessionID)
+      }
+    },
+    "tool.execute.before": async (input: ToolInput, output: ToolOutput) => {
+      if (input.tool === "task" && isRecord(output.args) && typeof output.args.task_id === "string") {
+        if (activatedSessions.has(input.sessionID)) return
+        if (!client || !directory) return
+        const targetSessionID = output.args.task_id.trim()
+        if (activatedSessions.has(targetSessionID)) throw new WorkflowScopeViolation("workflow continuation")
+        const parentID = await getSessionParent(client, directory, targetSessionID)
+        if (parentID && activatedSessions.has(parentID)) {
+          throw new WorkflowScopeViolation("workflow child continuation")
+        }
+        const restrictedAgent = await getSessionRestrictedAgent(client, directory, targetSessionID)
+        if (restrictedAgent) throw new WorkflowScopeViolation(restrictedAgent)
+        return
+      }
+      const restrictedAgent = findDelegatedRestrictedAgent(input.tool, output.args)
+      if (restrictedAgent && !activatedSessions.has(input.sessionID)) {
+        throw new WorkflowScopeViolation(restrictedAgent)
+      }
+    },
+    "chat.params": async (input: ChatParamsInput) => {
+      const restrictedAgent = normalizeRestrictedAgent(input.agent)
+      if (restrictedAgent && !(await isAuthorizedSession(input.sessionID))) {
+        throw new WorkflowScopeViolation(restrictedAgent)
+      }
+    },
+    event: async ({ event }: { readonly event: unknown }) => {
+      if (!isRecord(event) || event.type !== "session.deleted" || !isRecord(event.properties)) return
+      const info = event.properties.info
+      if (isRecord(info) && typeof info.id === "string") activatedSessions.delete(info.id)
+    },
+  }
+})
