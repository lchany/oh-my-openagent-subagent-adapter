+PATCH_SHA="$(awk '/^  sha256:/ {print $2}' "$MANIFEST")"
+test "$(sha256sum "$ROOT/versions/v1/$PATCH_PATH" | awk '{print $1}')" = "$PATCH_SHA"
+
