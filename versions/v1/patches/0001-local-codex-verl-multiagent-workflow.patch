+if ASCEND_RT_VISIBLE_DEVICES=0,1,2,3,4,5,6,7 "$GATE" "${base_args[@]}" --npu-devices 8,9,10,11,12,13,14,15 -- >/dev/null 2>&1; then exit 1; fi
