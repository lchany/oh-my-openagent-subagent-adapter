-status: fixed|blocked|failed|needs_retry
-root_cause_summary: "<=200 chars"
-root_cause_artifact: "runs/{run-id}/debug/root-cause.md"
-rca_confidence: high|medium|low|unknown
-first_failure_boundary: "<=200 chars"
-root_cause_location: code|config|data|environment|dependency|runtime|workflow_contract|unknown
-fix_summary: "<=200 chars"
-evidence_paths: []
-retry_command: "redacted or empty"
-remaining_risk: ""
-next_action: "retry previous phase|block|ask user"
-retry_phase_agent: "environment|baseline|implementation|optimized|comparison|empty"
-max_attempts_reached: true|false
-checkpoint_artifact: "runs/{run-id}/debug/checkpoint.md"
-change_ledger_artifact: "runs/{run-id}/debug/change-ledger.md"
-```
